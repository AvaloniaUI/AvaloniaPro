<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AccelerateDemo.ViewModels.WebView"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AccelerateDemo.Views.WebView.WebViewDemoView"
             x:DataType="vm:WebViewDemoViewModel">

    <DockPanel Margin="32,28,32,32">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="WebView"
                       FontSize="28" FontWeight="Black"
                       LetterSpacing="-0.5"/>
            <TextBlock Text="Embedded native web browser using platform rendering engines."
                       Foreground="{DynamicResource SubtleForeground}"
                       FontSize="14" LineHeight="22"/>
        </StackPanel>

        <!-- Address Bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Margin="0,0,0,16"
                BoxShadow="0 1 3 0 #08000000">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                <Button Grid.Column="0" Content="&#x2190;" Padding="10,6" Margin="0,0,4,0"
                        CornerRadius="6" FontSize="14"
                        x:Name="BackButton" Click="OnBackClick"/>
                <Button Grid.Column="1" Content="&#x2192;" Padding="10,6" Margin="0,0,4,0"
                        CornerRadius="6" FontSize="14"
                        x:Name="ForwardButton" Click="OnForwardClick"/>
                <Button Grid.Column="2" Content="&#x21BB;" Padding="10,6" Margin="0,0,8,0"
                        CornerRadius="6" FontSize="14"
                        x:Name="RefreshButton" Click="OnRefreshClick"/>
                <TextBox Grid.Column="3" Text="{Binding AddressText}"
                         Watermark="Enter URL..."
                         CornerRadius="6"
                         Padding="10,6"
                         BorderThickness="1"
                         KeyDown="OnAddressKeyDown"/>
                <Button Grid.Column="4" Content="Go"
                        Padding="16,6" Margin="4,0,0,0"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Command="{Binding NavigateCommand}"/>
            </Grid>
        </Border>

        <!-- WebView -->
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True"
                BoxShadow="0 1 3 0 #08000000">
            <NativeWebView x:Name="WebView"
                            Source="{Binding CurrentUri}"
                            EnvironmentRequested="WebView_OnEnvironmentRequested"
                            NavigationCompleted="OnNavigationCompleted"/>
        </Border>
    </DockPanel>
</UserControl>
