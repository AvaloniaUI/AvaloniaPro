<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AccelerateDemo.ViewModels.DataGrid"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AccelerateDemo.Views.DataGrid.EditableDataGridView"
             x:DataType="vm:EditableDataGridViewModel">

    <DockPanel Margin="32,28,32,32">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Editable Data Grid"
                       FontSize="28" FontWeight="Black"
                       LetterSpacing="-0.5"/>
            <TextBlock Text="Tap cells to edit values in-place. Use the checkbox column to select rows for deletion."
                       Foreground="{DynamicResource SubtleForeground}"
                       FontSize="14" LineHeight="22"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Margin="0,0,0,16"
                BoxShadow="0 1 3 0 #08000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add Row"
                        Command="{Binding AddRowCommand}"
                        Padding="16,7"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="6"
                        FontSize="13"
                        FontWeight="SemiBold"/>
                <Button Content="Remove Selected"
                        Command="{Binding RemoveSelectedCommand}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True"
                BoxShadow="0 1 3 0 #08000000">
            <TreeDataGrid Source="{Binding Source}"/>
        </Border>
    </DockPanel>
</UserControl>
