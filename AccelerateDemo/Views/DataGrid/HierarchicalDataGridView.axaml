<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AccelerateDemo.ViewModels.DataGrid"
             xmlns:models="using:AccelerateDemo.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AccelerateDemo.Views.DataGrid.HierarchicalDataGridView"
             x:DataType="vm:HierarchicalDataGridViewModel">

    <UserControl.Resources>
        <DataTemplate x:Key="FileNameCellTemplate" x:DataType="models:FileSystemNode">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <PathIcon Width="16" Height="16"
                          Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                          Foreground="#FFC107"
                          IsVisible="{Binding IsFolder}"/>
                <PathIcon Width="16" Height="16"
                          Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"
                          Foreground="#64B5F6"
                          IsVisible="{Binding !IsFolder}"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Margin="32,28,32,32">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Hierarchical Data Grid"
                       FontSize="28" FontWeight="Black"
                       LetterSpacing="-0.5"/>
            <TextBlock Text="File system tree with expand/collapse, nested nodes, and column sorting."
                       Foreground="{DynamicResource SubtleForeground}"
                       FontSize="14" LineHeight="22"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Margin="0,0,0,16"
                BoxShadow="0 1 3 0 #08000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Expand All"
                        Command="{Binding ExpandAllCommand}"
                        Padding="16,7"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="6"
                        FontSize="13"
                        FontWeight="SemiBold"/>
                <Button Content="Collapse All"
                        Command="{Binding CollapseAllCommand}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Grid -->
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True"
                BoxShadow="0 1 3 0 #08000000">
            <TreeDataGrid Source="{Binding Source}"/>
        </Border>
    </DockPanel>
</UserControl>
