<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AccelerateDemo.ViewModels.Markdown"
             xmlns:textMate="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.Markdown.TextMate"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AccelerateDemo.Views.Markdown.MarkdownDemoView"
             x:DataType="vm:MarkdownDemoViewModel">

    <UserControl.Resources>
        <textMate:TextMateHighlighter x:Key="textMateHighlighter" Theme="LightPlus"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.active">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="32,28,32,32">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Markdown Renderer"
                       FontSize="28" FontWeight="Black"
                       LetterSpacing="-0.5"/>
            <TextBlock Text="Edit Markdown on the left, see rendered output on the right. Toggle editor visibility or load sample content."
                       Foreground="{DynamicResource SubtleForeground}"
                       FontSize="14" LineHeight="22"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Margin="0,0,0,16"
                BoxShadow="0 1 3 0 #08000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="README"
                        Command="{Binding LoadReadmeCommand}"
                        Classes.active="{Binding IsReadmeSelected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
                <Button Content="Features"
                        Command="{Binding LoadFeaturesCommand}"
                        Classes.active="{Binding IsFeaturesSelected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
                <Button Content="Code Blocks"
                        Command="{Binding LoadCodeBlocksCommand}"
                        Classes.active="{Binding IsCodeBlocksSelected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
                <Border Width="1" Background="{DynamicResource SectionDivider}"
                        Margin="4,4" VerticalAlignment="Stretch"/>
                <Button Content="Toggle Editor"
                        Command="{Binding ToggleEditorCommand}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Split Pane -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Editor -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    IsVisible="{Binding IsEditorVisible}"
                    Margin="0,0,8,0"
                    BoxShadow="0 1 3 0 #08000000"
                    ClipToBounds="True">
                <TextBox Text="{Binding MarkdownText}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas,Menlo,monospace"
                         FontSize="13"
                         BorderThickness="0"
                         Padding="16"/>
            </Border>

            <!-- Preview when editor visible -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    IsVisible="{Binding IsEditorVisible}"
                    Margin="8,0,0,0"
                    BoxShadow="0 1 3 0 #08000000"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Markdown Text="{Binding MarkdownText}"
                              CodeHighlighter="{StaticResource textMateHighlighter}"
                              Margin="16"/>
                </ScrollViewer>
            </Border>

            <!-- Full-width preview when editor hidden -->
            <Border Grid.Column="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    IsVisible="{Binding !IsEditorVisible}"
                    BoxShadow="0 1 3 0 #08000000"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <Markdown Text="{Binding MarkdownText}"
                              CodeHighlighter="{StaticResource textMateHighlighter}"
                              Margin="16"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
