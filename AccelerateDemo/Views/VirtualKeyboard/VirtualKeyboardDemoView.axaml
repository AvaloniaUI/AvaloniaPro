<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AccelerateDemo.ViewModels.VirtualKeyboard"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="AccelerateDemo.Views.VirtualKeyboard.VirtualKeyboardDemoView"
             x:DataType="vm:VirtualKeyboardDemoViewModel">

    <DockPanel Margin="32,28,32,32">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Virtual Keyboard"
                       FontSize="28" FontWeight="Black"
                       LetterSpacing="-0.5"/>
            <TextBlock Text="On-screen keyboard for touch and kiosk scenarios. Click on any input field to activate the keyboard."
                       Foreground="{DynamicResource SubtleForeground}"
                       FontSize="14" LineHeight="22"/>
        </StackPanel>

        <!-- Form with Virtual Keyboard -->
        <VirtualKeyboardScope InputMethods="en-US:kbd:standard, de:kbd:standard, fr:kbd:standard, ja:ime:kana">
            <ScrollViewer>
                <Border Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="28,24"
                        BoxShadow="0 1 3 0 #08000000"
                        MaxWidth="520"
                        HorizontalAlignment="Left">
                    <StackPanel Spacing="20">

                        <StackPanel Spacing="6">
                            <TextBlock Text="Name" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox Text="{Binding NameText}"
                                     Watermark="Enter your name"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Email" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox Text="{Binding EmailText}"
                                     Watermark="Enter your email address"
                                     TextInputOptions.ContentType="Email"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Search" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox Text="{Binding SearchText}"
                                     Watermark="Search..."
                                     TextInputOptions.ReturnKeyType="Search"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox Text="{Binding NotesText}"
                                     Watermark="Enter additional notes"
                                     AcceptsReturn="True"
                                     Height="120"
                                     TextWrapping="Wrap"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource SectionDivider}"
                                Margin="0,4"/>

                        <TextBlock Text="Supports multiple languages: English, German, French, Japanese"
                                   Foreground="{DynamicResource SubtleForeground}"
                                   FontSize="12.5"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </VirtualKeyboardScope>
    </DockPanel>
</UserControl>
