<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaProDemo.ViewModels.MediaPlayer"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaProDemo.Views.MediaPlayer.MediaPlayerView"
             x:DataType="vm:MediaPlayerViewModel">

    <UserControl.Styles>
        <Style Selector="Button.active">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="32,28,32,32">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Media Player"
                       FontSize="28" FontWeight="Black"
                       LetterSpacing="-0.5"/>
            <TextBlock Text="Cross-platform audio and video playback with transport controls, seeking, and volume."
                       Foreground="{DynamicResource SubtleForeground}"
                       FontSize="14" LineHeight="22"/>
        </StackPanel>

        <!-- Source Selection Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Margin="0,0,0,16"
                BoxShadow="0 1 3 0 #08000000">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Big Buck Bunny"
                        Click="LoadSample1_Click"
                        Classes.active="{Binding IsSample1Selected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
                <Button Content="Elephants Dream"
                        Click="LoadSample2_Click"
                        Classes.active="{Binding IsSample2Selected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
                <Button Content="Sintel"
                        Click="LoadSample3_Click"
                        Classes.active="{Binding IsSample3Selected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
                <Border Width="1" Background="{DynamicResource SectionDivider}"
                        Margin="4,4" VerticalAlignment="Stretch"/>
                <Button Content="Open File..."
                        Click="OpenFile_Click"
                        Classes.active="{Binding IsFileSelected}"
                        Padding="16,7"
                        CornerRadius="6"
                        FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Player -->
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True"
                BoxShadow="0 1 3 0 #08000000">
            <MediaPlayerControl x:Name="mediaPlayer"
                                Volume="0.8"
                                LoadedBehavior="AutoPlay"
                                SkipTime="0:0:10"/>
        </Border>
    </DockPanel>
</UserControl>
